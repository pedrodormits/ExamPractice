# This .gitignore file should be placed at the root of your Unity project.

############################
# Unity generated folders
############################

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Rr]ecordings/

############################
# Asset Import Pipeline
############################

Assets/AssetStoreTools*

############################
# Visual Studio / Rider
############################

.vs/
.vscode/
.idea/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

############################
# Unity Collaborate
############################

.collabignore

############################
# OS files
############################

.DS_Store
Thumbs.db
Desktop.ini

############################
# Crash reports
############################

sysinfo.txt

############################
# Addressables
############################

ServerData/

############################
# Android
############################

.gradle/
*.apk
*.aab

############################
# Generated files
############################

*.pidb.meta
*.pdb.meta
*.mdb.meta

############################
# Ignore Rider cache
############################

.idea/

############################
# Keep these folders in Git
############################
!Assets/
!Packages/
!ProjectSettings/
!UserSettings/